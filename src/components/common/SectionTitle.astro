---
interface Props {
  eyebrow?: string;
  title: string;
  variant?: 'blue' | 'white' | 'yellow';
}

const {
  eyebrow,
  title,
  variant = 'blue',
} = Astro.props;
---

<div class={`section-title section-title--${variant}`}>
  {eyebrow && <p>{eyebrow}</p>}
  <h2>{title}</h2>
</div>

<style>
  .section-title {
    text-align: center;
  }

  .section-title p,
  .section-title h2 {
    margin: 0;
  }

  .section-title p {
    font-weight: 900;
    font-size: clamp(1rem, 3vw, 1.35rem);
  }

  .section-title h2 {
    margin-top: 4px;
    font-size: clamp(2.2rem, 9vw, 4.8rem);
    line-height: 0.9;
    font-weight: 1000;
    letter-spacing: -0.04em;
  }

  .section-title--blue {
    color: var(--color-blue-main);
    text-shadow: 0 5px 0 #fff;
  }

  .section-title--white {
    color: var(--color-white);
  }

  .section-title--yellow {
    color: var(--color-yellow);
  }
</style>
