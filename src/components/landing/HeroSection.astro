---
import { eventInfo } from '@data/event';
const withBase = (path: string) => `${import.meta.env.BASE_URL}${path.replace(/^\//, '')}`;

const heroAssets = {
  background: withBase('/images/festival-kids/hero/Fondo_portada_principal_Festival_Kids (1).webp'),
  logo: withBase('/images/festival-kids/hero/LOGO_LEMA_FESTIVAL KIDS.webp'),
  datePlace: withBase('/images/festival-kids/hero/FECHA_LUGAR_FESTIVAL_KIDS.webp'),
};
---

<section class="hero" id="inicio" aria-labelledby="hero-title">
  <div class="hero__background" aria-hidden="true"></div>

  <div class="hero__content">
    <div class="hero__copy">
      <h1 id="hero-title" class="visually-hidden">
        {eventInfo.name} - {eventInfo.claim} - {eventInfo.dateLabel} en {eventInfo.location}
      </h1>

      <img
        class="hero__logo"
        src={heroAssets.logo}
        alt="Festival Kids - Una aventura sin límites"
        loading="eager"
        decoding="async"
      />

      <img
        class="hero__date"
        src={heroAssets.datePlace}
        alt={`${eventInfo.dateLabel} - ${eventInfo.location}`}
        loading="eager"
        decoding="async"
      />

      <a class="hero__cta" href={eventInfo.heroCta.href}>
        {eventInfo.heroCta.label}
      </a>
    </div>
  </div>
</section>

<style define:vars={{ heroBackground: `url("${heroAssets.background}")` }}>
  .hero {
    position: relative;
    width: 100%;
    min-height: clamp(760px, 56.25vw, 1040px);
    overflow: hidden;
    background-color: #159dec;
    isolation: isolate;
  }

  .hero__background {
    position: absolute;
    inset: 0;
    z-index: -2;
    background-color: #159dec;
    background-image: var(--heroBackground);
    background-repeat: no-repeat;
    background-size: cover;
    background-position: center top;
  }

  .hero__background::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        90deg,
        rgba(0, 122, 206, 0.12) 0%,
        rgba(0, 122, 206, 0.04) 32%,
        rgba(0, 122, 206, 0) 62%
      );
    pointer-events: none;
  }

  .hero__content {
    position: relative;
    z-index: 2;
    width: min(100% - 32px, 1360px);
    min-height: inherit;
    margin-inline: auto;
    display: flex;
    align-items: flex-start;
    padding-top: clamp(42px, 4.8vw, 72px);
  }

 .hero__copy {
  display: grid;
  justify-items: center;
  width: min(100%, 520px);
  margin-left: clamp(0px, 5vw, 96px);
}

  .hero__logo {
  width: clamp(280px, 30vw, 430px);
  height: auto;
  filter: drop-shadow(0 8px 10px rgba(0, 88, 150, 0.18));
}

.hero__date {
  width: clamp(330px, 38vw, 520px);
  height: auto;
  margin-top: clamp(8px, 1vw, 16px);
  filter: drop-shadow(0 8px 10px rgba(0, 88, 150, 0.18));
}

  .hero__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 180px;
    min-height: 56px;
    margin-top: clamp(14px, 2vw, 24px);
    padding: 12px 28px;
    border-radius: 999px;
    background: #ffe600;
    color: #ef4b18;
    font-family: var(--font-ui);
    font-size: clamp(1.1rem, 1.6vw, 1.5rem);
    font-weight: 700;
    letter-spacing: 0.01em;
    line-height: 1;
    box-shadow:
      0 10px 0 rgba(238, 181, 0, 0.85),
      0 18px 30px rgba(0, 0, 0, 0.18);
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      filter 180ms ease;
  }

  .hero__cta:hover {
    transform: translateY(-3px);
    filter: brightness(1.03);
    box-shadow:
      0 13px 0 rgba(238, 181, 0, 0.85),
      0 22px 34px rgba(0, 0, 0, 0.22);
  }

  .hero__cta:active {
    transform: translateY(2px);
    box-shadow:
      0 6px 0 rgba(238, 181, 0, 0.85),
      0 14px 24px rgba(0, 0, 0, 0.18);
  }

  @media (max-width: 767px) {
    .hero {
      min-height: 760px;
    }

    .hero__background {
      background-size: auto 100%;
      background-position: 58% top;
    }

    .hero__background::after {
      background:
        linear-gradient(
          to bottom,
          rgba(0, 136, 220, 0.06) 0%,
          rgba(0, 136, 220, 0.01) 46%,
          rgba(0, 0, 0, 0.12) 100%
        );
    }

    .hero__content {
      width: min(100% - 24px, 430px);
      justify-content: center;
      padding-top: 28px;
    }

    .hero__copy {
      width: min(100%, 360px);
      margin-left: 0;
    }

    .hero__logo {
      width: min(76vw, 300px);
    }

    .hero__date {
      width: min(84vw, 350px);
    }

    .hero__cta {
      min-width: 168px;
      min-height: 52px;
    }
  }

  @media (min-width: 768px) and (max-width: 1023px) {
    .hero {
      min-height: 760px;
    }

    .hero__background {
      background-position: 55% top;
    }

    .hero__content {
      width: min(100% - 40px, 960px);
      padding-top: 42px;
    }

    .hero__copy {
      margin-left: clamp(0px, 3vw, 32px);
    }
  }

  @media (min-width: 1024px) and (max-width: 1279px) {
    .hero {
      min-height: clamp(760px, 60vw, 900px);
    }

    .hero__background {
      background-position: 53% top;
    }

    .hero__copy {
      margin-left: clamp(24px, 4vw, 64px);
    }
  }

  @media (min-width: 1280px) and (max-width: 1599px) {
    .hero {
      min-height: clamp(780px, 56.25vw, 940px);
    }

    .hero__background {
      background-position: center top;
    }
  }

  @media (min-width: 1600px) {
    .hero {
      min-height: clamp(920px, 56.25vw, 1080px);
    }

    .hero__background {
      background-position: center top;
    }

    .hero__content {
      width: min(100% - 48px, 1480px);
      padding-top: clamp(56px, 4vw, 82px);
    }
  }

  @media (min-width: 1920px) {
    .hero {
      min-height: 1080px;
    }
  }
</style>